<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      PACKAGE_USAGE_STATS: 利用統計取得の特別権限（appop / ARCHITECTURE §4-6）。
      宣言しないと OS設定「使用状況へのアクセス」にアプリが出ないため必須。
      tools:ignore="ProtectedPermissions" は lint 警告抑止（保護権限の意図的宣言）。
      審査: 機微権限。用途を「SNS利用時間の削減ゲーム化」とプライバシーポリシー/
      データ安全性フォームに明示（法務部署と整合）。
    -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- ネットワーク（Supabase 同期 / 接続検知） -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
      AdMob 広告ID（core/ads のバナー広告）。targetSdk 33+ で広告ID(AD_ID)取得に必須。
      データ安全性フォームで「広告ID収集（目的=広告）」を必ず申告（docs/legal/STORE_DATA_SAFETY.md）。
    -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />

    <application
        android:label="Moffy"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!--
          AdMob アプリID（無料プランのバナー広告 / core/ads）。合同会社Lan の実アプリID。
          既定（開発/内部テスト）は lib/core/ads/ad_config.dart がテスト広告ユニットを使うため、
          この実アプリIDでも出るのはテスト広告のみ＝自クリック安全。実広告の実配信は
          「本番公開ビルド（--dart-define=ADMOB_USE_PROD_ADS=true）＋AdMob 審査承認後（一般公開後）」。
          広告ユニットIDの切替は ad_config.dart 側。
        -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-5063966757462588~9241790104" />
    </application>
</manifest>

# Flutter / Dart
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
pubspec.lock

# 生成コード（build_runner）はコミット方針次第。MVPでは生成物を無視。
*.g.dart
*.freezed.dart

# Android（端末固有・秘密情報）
android/local.properties
android/key.properties
*.keystore
*.jks
android/.gradle/
.gradle/

# 環境変数（Supabase URL/anon key を埋め込まない / 信頼境界）
.env
.env.*
!.env.example

# 秘密メモ置き場（Webhook共有シークレット等・誤コミット防止）
secrets/
*.secret

# Supabase CLI のローカル一時ファイル（project-ref 等・リポジトリに含めない）
supabase/.temp/

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Mofi 生データ置き場（オーナー生成の元画像・切り分け前。最終物は assets/images/mofi/ へ配置）
assets/images/mofi_raw/

# 色違いの元画像ドロップ置き場（オーナーが任意の名前で置く→私が識別・リネーム・処理して
# assets/images/mofi/ の mofi_<id>_<stage>_shiny.png へ配置。元画像はリポジトリに含めない）
assets/images/mofi_shiny_raw/

# App-dev tooling / 大容量物（アプリ本体のリポジトリには含めない）
.claude/
app-dev-org/
asc-mcp/
flutter_sdk.zip
.claude/settings.local.json
.claude/gpc/

# 色違い確認用の書き出し画像（レビュー用・アプリには不要＝プログラムで色変換）
shiny_preview/
